{
  "name": "cascade",
  "version": "0.6.0",
  "description": "Declarative streaming library inspired by Apache Camel and Benthos",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/cascade",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "e2e:all": "./tests/e2e/run-all-tests.sh",
    "e2e:redis-pubsub": "./tests/e2e/scripts/test-redis-pubsub.sh",
    "e2e:redis-list": "./tests/e2e/scripts/test-redis-list.sh",
    "e2e:redis-streams": "./tests/e2e/scripts/test-redis-streams.sh",
    "e2e:sqs": "./tests/e2e/scripts/test-sqs.sh",
    "e2e:http-input": "./tests/e2e/scripts/test-http-input.sh",
    "e2e:http-output": "./tests/e2e/scripts/test-http-output.sh",
    "e2e:http-processor": "./tests/e2e/scripts/test-http-processor.sh",
    "e2e:http-processor-post": "./tests/e2e/scripts/test-http-processor-post.sh",
    "e2e:http-processor-auth": "./tests/e2e/scripts/test-http-processor-auth.sh",
    "e2e:http-processor-errors": "./tests/e2e/scripts/test-http-processor-errors.sh",
    "e2e:http-processor-retry": "./tests/e2e/scripts/test-http-processor-retry.sh",
    "e2e:http-processor-templates": "./tests/e2e/scripts/test-http-processor-templates.sh",
    "run-pipeline": "tsx src/cli.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "author": "Marcelo Santos (@marcelsud)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelsud/cascade.git"
  },
  "homepage": "https://github.com/marcelsud/cascade#readme",
  "bugs": {
    "url": "https://github.com/marcelsud/cascade/issues"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.705.0",
    "@effect/platform": "^0.93.0",
    "@effect/platform-node": "^0.100.0",
    "@smithy/node-http-handler": "^4.4.5",
    "effect": "^3.19.3",
    "ioredis": "^5.4.2",
    "jsonata": "^2.1.0",
    "quickjs-emscripten": "^0.32.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
